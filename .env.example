PROVIDER=openai
OPENAI_API_KEY=
GOOGLE_API_KEY=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=semantic_search
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PGVECTOR_COLLECTION=document_chunks

# Path to the PDF to ingest
PDF_PATH=document.pdf

# Optional: full database URL (overrides individual POSTGRES_* vars if set)
DATABASE_URL=

# Optional: override embedding model names
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GOOGLE_EMBEDDING_MODEL=models/embedding-001